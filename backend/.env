# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── SQL Server ───────────────────────────────────────────
DB_SERVER=DESKTOP-8FPFPER\SQLEXPRESS
DB_PORT=
DB_NAME=NEW_Production
DB_USER=sa
DB_PASSWORD=123456789
DB_ENCRYPT=false             # set true for Azure SQL
DB_TRUST_CERT=true        
# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=bpap_super_secret_key_change_in_production_2025
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=bpap_refresh_secret_key_change_in_production_2025
