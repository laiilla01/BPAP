# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── SQL Server ───────────────────────────────────────────
DB_SERVER=localhost          # or your Windows machine IP
DB_PORT=1433
DB_NAME=BPAP_DB
DB_USER=sa
DB_PASSWORD=YourStrongPassword!
DB_ENCRYPT=false             # set true for Azure SQL
DB_TRUST_CERT=true           # set false in production with proper cert

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=bpap_super_secret_key_change_in_production_2025
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=bpap_refresh_secret_key_change_in_production_2025
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
